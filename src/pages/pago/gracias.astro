---
import Base from "../../layouts/Base.astro";
---

<Base title="¡Pago exitoso! — WebP Convert Pro" description="Tu plan Pro ha sido activado.">
  <div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-4 text-center font-mono">
    <div class="w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-6">
      <span class="text-3xl">✓</span>
    </div>
    <h1 class="text-3xl font-bold text-white mb-3">¡Ya eres Pro!</h1>
    <p class="text-zinc-400 text-sm max-w-md mb-8">
      Tu plan Pro ha sido activado. Ya puedes convertir imágenes sin límite.
      Recibirás un correo de confirmación en breve.
    </p>
    <a
      href="/"
      class="bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-bold px-6 py-3 rounded-xl transition-colors text-sm"
    >
      Empezar a convertir →
    </a>
  </div>
</Base>
