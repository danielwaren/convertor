---
import Base from "../../layouts/Base.astro";
---

<Base title="Pago pendiente — WebP Convert" description="Tu pago está siendo procesado.">
  <div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-4 text-center font-mono">
    <div class="w-16 h-16 rounded-full bg-yellow-500/10 border border-yellow-500/30 flex items-center justify-center mb-6">
      <span class="text-3xl">⏳</span>
    </div>
    <h1 class="text-3xl font-bold text-white mb-3">Pago en proceso</h1>
    <p class="text-zinc-400 text-sm max-w-md mb-8">
      MercadoPago está procesando tu pago. Una vez confirmado, tu plan Pro se activará automáticamente.
      Puedes cerrar esta ventana.
    </p>
    <a href="/" class="text-sm text-emerald-400 hover:text-emerald-300 transition-colors">
      ← Volver al inicio
    </a>
  </div>
</Base>
