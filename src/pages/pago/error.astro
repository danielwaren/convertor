---
import Base from "../../layouts/Base.astro";
---

<Base title="Error en el pago — WebP Convert" description="Hubo un problema con tu pago.">
  <div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-4 text-center font-mono">
    <div class="w-16 h-16 rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center mb-6">
      <span class="text-3xl">✕</span>
    </div>
    <h1 class="text-3xl font-bold text-white mb-3">Pago no completado</h1>
    <p class="text-zinc-400 text-sm max-w-md mb-8">
      El pago no fue procesado. No se realizó ningún cargo. Puedes intentarlo nuevamente.
    </p>
    <a
      href="/"
      class="bg-zinc-800 hover:bg-zinc-700 text-zinc-300 px-6 py-3 rounded-xl transition-colors text-sm"
    >
      ← Volver e intentar de nuevo
    </a>
  </div>
</Base>
