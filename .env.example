# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontrarás estos valores en: supabase.com → tu proyecto → Settings → API
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Vercel KV (Redis) ──────────────────────────────────────────────────────────
# Se generan automáticamente al crear el KV Store en Vercel → Storage
KV_REST_API_URL=https://xxxxxxxxxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Encontrarás estos valores en: mercadopago.com → Tu negocio → Credenciales
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_ACCESS_TOKEN_TEST=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# ── Sitio ─────────────────────────────────────────────────────────────────────
# URL pública de tu app en Vercel, sin slash al final
PUBLIC_SITE_URL=https://tu-app.vercel.app
